# Terraform state files
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform working directory
.terraform/
.terraform.lock.hcl

# Terraform variable files (may contain secrets)
*.tfvars
*.tfvars.json
!example.tfvars

# Terraform plan output files
*.tfplan
*.plan
plan.out

# Terraform crash logs
crash.log
crash.*.log

# Terraform override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Provider credentials and sensitive config
*.pem
*.key
*.crt
*.p12
*.pfx
secrets.tf
credentials.tf

# Environment variable files
.env
.env.*
!.env.example

# OS generated files
.DS_Store
Thumbs.db

# Editor/IDE files
.vscode/
.idea/
*.swp
*.swo
*~
